    def load_config(self):
        if os.path.exists(self.config_file):
            try:
                with open(self.config_file, 'r') as f:
                    return json.load(f)
            except:
                return {}
        return {}
    
    def save_config(self):
        try:
            config = {
                'window_coords': self.window_coords,
                'window_settings': {},
                'global_message_list': self.global_message_list,
                'global_x': self.x_var.get(),
                'global_y': self.y_var.get(),
                'global_delay': self.delay_var.get(),
                'global_message': self.message_var.get(),
                'random_mode': self.random_var.get(),
                'ui_scale': self.scale_var.get(),
                'dark_mode': self.dark_mode,
                'post_msg_delay_min': self.post_msg_delay_min.get(),
                'post_msg_delay_max': self.post_msg_delay_max.get(),
                'post_msg_random': self.post_msg_random.get()
            }
            for window_info in self.habbo_windows:
                title = window_info['title']
                config['window_settings'][title] = {
                    'custom_message': window_info['custom_message'].get(),
                    'use_custom': window_info['use_custom'].get(),
                    'delay_after_prev': window_info['delay_after_prev'].get(),
                    'post_msg_delay_min': window_info['post_msg_delay_min'].get(),
                    'post_msg_delay_max': window_info['post_msg_delay_max'].get(),
                    'post_msg_random': window_info['post_msg_random'].get()
                }
            with open(self.config_file, 'w') as f:
                json.dump(config, f, indent=2)
        except Exception as e:
            print(f"Failed to save config: {e}")
    
    def load_window_settings(self, title):
        if hasattr(self, 'config') and 'window_settings' in self.config:
            settings = self.config['window_settings'].get(title, {})
            return {
                'custom_message': settings.get('custom_message', ''),
                'use_custom': settings.get('use_custom', False),
                'delay_after_prev': settings.get('delay_after_prev', 0),
                'post_msg_delay_min': settings.get('post_msg_delay_min', 1.0),
                'post_msg_delay_max': settings.get('post_msg_delay_max', 1.0),
                'post_msg_random': settings.get('post_msg_random', False)
            }
        return {
            'custom_message': '', 'use_custom': False, 'delay_after_prev': 0,
            'post_msg_delay_min': 1.0, 'post_msg_delay_max': 1.0, 'post_msg_random': False
        }
    
    def check_packages(self):
        required_packages = ['pyautogui', 'pygetwindow', 'pywin32']
        missing_packages = []
        
        for package in required_packages:
            try:
                if package == 'pyautogui':
                    import pyautogui
                elif package == 'pygetwindow':
                    import pygetwindow
                elif package == 'pywin32':
                    import win32gui
            except ImportError:
                missing_packages.append(package)
        
        if missing_packages:
            response = messagebox.askyesno(
                "Install Packages",
                f"Missing packages: {', '.join(missing_packages)}\n\nDo you want to install them now?"
            )
            if response:
                self.install_packages(missing_packages)
                messagebox.showinfo("Restart Required", "Please restart the application.")
                self.root.destroy()
                return False
            else:
                messagebox.showwarning("Packages Required", "The application cannot run without the required packages.")
                self.root.destroy()
                return False
        return True
    
    def install_packages(self, packages):
        for package in packages:
            try:
                if package == 'pywin32':
                    package = 'pypiwin32'
                subprocess.check_call([sys.executable, "-m", "pip", "install", package])
                print(f"Successfully installed {package}")
            except Exception as e:
                print(f"Failed to install {package}: {e}")
    

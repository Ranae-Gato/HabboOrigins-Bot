    def get_message_list(self):
        messages = self.message_list_text.get('1.0', tk.END).strip().split('\n')
        return [msg.strip() for msg in messages if msg.strip()]
    
    def toggle_dark_mode(self):
        self.dark_mode = self.dark_mode_var.get()
        self.save_config()
        
        theme = 'dark' if self.dark_mode else 'light'
        colors = self.colors[theme]
        
        style = ttk.Style()
        style.theme_use('clam')
        
        style.configure('TFrame', background=colors['bg'])
        style.configure('TLabel', background=colors['bg'], foreground=colors['label_fg'])
        style.configure('TButton', background=colors['button_bg'], foreground=colors['button_fg'])
        style.configure('TCheckbutton', background=colors['bg'], foreground=colors['fg'])
        style.configure('TRadiobutton', background=colors['bg'], foreground=colors['fg'])
        style.configure('TLabelframe', background=colors['frame_bg'], foreground=colors['label_fg'])
        style.configure('TLabelframe.Label', background=colors['frame_bg'], foreground=colors['label_fg'])
        
        self.root.configure(bg=colors['bg'])
        
        for widget in self.root.winfo_children():
            self.update_widget_colors(widget, colors)
    
    def update_widget_colors(self, widget, colors):
        try:
            widget_class = widget.winfo_class()
            
            if widget_class in ('Frame', 'Canvas'):
                widget.configure(bg=colors['bg'])
            elif widget_class == 'Label':
                widget.configure(bg=colors['bg'], fg=colors['label_fg'])
            elif widget_class == 'Entry':
                widget.configure(bg=colors['entry_bg'], fg=colors['entry_fg'], insertbackground=colors['entry_fg'])
            elif widget_class == 'Text':
                widget.configure(bg=colors['text_bg'], fg=colors['text_fg'], insertbackground=colors['text_fg'])
            elif widget_class == 'Scrollbar':
                widget.configure(bg=colors['button_bg'])
            
            for child in widget.winfo_children():
                self.update_widget_colors(child, colors)
        except:
            pass
    
    def apply_scale(self):
        try:
            scale = self.scale_var.get()
            if scale < 0.5 or scale > 2.0:
                messagebox.showwarning("Invalid Scale", "Scale must be between 0.5 and 2.0")
                return
            
            self.root.tk.call('tk', 'scaling', scale)
            self.save_config()
            
            try:
                self.root.unbind_all("<MouseWheel>")
            except:
                pass
            
            for widget in self.root.winfo_children():
                widget.destroy()
            
            self.ui_scale = scale
            self.create_widgets()
            
            self.log_message(f"UI scale applied: {scale:.1f}")
        except Exception as e:
            self.log_message(f"Could not apply scale: {e}")
    
    def toggle_window_expanded(self, idx):
        if idx in self.expanded_windows:
            self.expanded_windows.discard(idx)
        else:
            self.expanded_windows.add(idx)
        self.scan_habbo_windows()
    
    def scan_habbo_windows(self):
        try:
            old_settings = {wi['title']: wi for wi in self.habbo_windows}
            
            self.habbo_windows = []
            self.window_vars = []
            
            for widget in self.window_list_frame.winfo_children():
                widget.destroy()
            
            all_windows = self.gw.getAllWindows()
            window_count = 0

            for window in all_windows:
                if window.title:
                    title_lower = window.title.lower()
                    if any(keyword in title_lower for keyword in ['habbo', 'flash', 'player']):
                        var = tk.BooleanVar(value=True)
                        self.window_vars.append(var)

                        window_key = window.title
                        saved_coords = self.window_coords.get(window_key, {})
                        coord_text = f"({saved_coords.get('x', '?')}, {saved_coords.get('y', '?')})" if saved_coords else "(Not set)"
                        
                        old_wi = old_settings.get(window_key, {})
                        settings = self.load_window_settings(window_key)
                        
                        if old_wi:
                            settings['custom_message'] = old_wi.get('custom_message', tk.StringVar()).get()
                            settings['use_custom'] = old_wi.get('use_custom', tk.BooleanVar()).get()
                            settings['delay_after_prev'] = old_wi.get('delay_after_prev', tk.DoubleVar()).get()
                            settings['post_msg_delay_min'] = old_wi.get('post_msg_delay_min', tk.DoubleVar()).get()
                            settings['post_msg_delay_max'] = old_wi.get('post_msg_delay_max', tk.DoubleVar()).get()
                            settings['post_msg_random'] = old_wi.get('post_msg_random', tk.BooleanVar()).get()

                        frame = ttk.Frame(self.window_list_frame)
                        frame.pack(anchor='w', padx=5, pady=2, fill=tk.X)
                        
                        top_row = ttk.Frame(frame)
                        top_row.pack(fill=tk.X)
                        
                        checkbox = ttk.Checkbutton(top_row, text=f"{window.title} - {coord_text}", variable=var, onvalue=True, offvalue=False)
                        checkbox.pack(side=tk.LEFT)
                        
                        set_btn = ttk.Button(top_row, text="Set", width=4, command=lambda w=window: self.set_coordinate_for_window(w))
                        set_btn.pack(side=tk.LEFT, padx=(10, 0))
                        
                        exp_btn = ttk.Button(top_row, text="[+]", width=3, command=lambda i=window_count: self.toggle_window_expanded(i))
                        exp_btn.pack(side=tk.LEFT, padx=(5, 0))
                        
                        custom_message_var = tk.StringVar(value=settings['custom_message'])
                        use_custom_var = tk.BooleanVar(value=settings['use_custom'])
                        delay_offset_var = tk.DoubleVar(value=settings['delay_after_prev'])
                        post_msg_min_var = tk.DoubleVar(value=settings['post_msg_delay_min'])
                        post_msg_max_var = tk.DoubleVar(value=settings['post_msg_delay_max'])
                        post_msg_random_var = tk.BooleanVar(value=settings['post_msg_random'])
                        dropdown_var = tk.StringVar()
                        
                        msg_list = self.get_message_list()
                        if msg_list:
                            dropdown_var.set(msg_list[0])
                        
                        wi_data = {
                            'handle': window._hWnd,
                            'title': window.title,
                            'window': window,
                            'coords': saved_coords,
                            'custom_message': custom_message_var,
                            'use_custom': use_custom_var,
                            'delay_after_prev': delay_offset_var,
                            'post_msg_delay_min': post_msg_min_var,
                            'post_msg_delay_max': post_msg_max_var,
                            'post_msg_random': post_msg_random_var,
                            'msg_dropdown_var': dropdown_var,
                            'frame': frame,
                            'top_row': top_row,
                            'exp_btn': exp_btn
                        }
                        
                        if window_count in self.expanded_windows:
                            exp_btn.configure(text="[-]")
                            self.create_expanded_row(wi_data, msg_list)
                        
                        self.habbo_windows.append(wi_data)
                        window_count += 1

            self.window_count_label.config(text=f"Detected: {window_count} windows")

            if self.habbo_windows:
                self.log_message(f"Found {window_count} Habbo window(s)")
            else:
                self.log_message("No Habbo windows found")

        except Exception as e:
            self.log_message(f"Error scanning: {str(e)}")
    
    def create_expanded_row(self, wi_data, msg_list):
        exp_row = ttk.Frame(wi_data['frame'])
        exp_row.pack(fill=tk.X, padx=20, pady=(2, 0))
        
        ttk.Checkbutton(exp_row, text="Custom:", variable=wi_data['use_custom']).pack(side=tk.LEFT)
        
        msg_frame = ttk.Frame(exp_row)
        msg_frame.pack(side=tk.LEFT, padx=(5, 10))
        ttk.Combobox(msg_frame, textvariable=wi_data['msg_dropdown_var'], values=msg_list, width=10, state='readonly').pack(side=tk.LEFT)
        
        ttk.Label(exp_row, text="Entry:").pack(side=tk.LEFT, padx=(5, 0))
        ttk.Entry(exp_row, textvariable=wi_data['custom_message'], width=8).pack(side=tk.LEFT, padx=(2, 10))
        
        ttk.Label(exp_row, text="Start offset:").pack(side=tk.LEFT, padx=(5, 0))
        ttk.Spinbox(exp_row, from_=0, to=30, increment=0.5, textvariable=wi_data['delay_after_prev'], width=5).pack(side=tk.LEFT, padx=(2, 10))
        ttk.Label(exp_row, text="sec").pack(side=tk.LEFT)
        
        ttk.Label(exp_row, text="Post-msg:").pack(side=tk.LEFT, padx=(10, 0))
        ttk.Spinbox(exp_row, from_=0, to=30, increment=0.5, textvariable=wi_data['post_msg_delay_min'], width=4).pack(side=tk.LEFT, padx=(2, 0))
        ttk.Label(exp_row, text="-").pack(side=tk.LEFT)
        ttk.Spinbox(exp_row, from_=0, to=30, increment=0.5, textvariable=wi_data['post_msg_delay_max'], width=4).pack(side=tk.LEFT, padx=(0, 2))
        ttk.Label(exp_row, text="s").pack(side=tk.LEFT)
        ttk.Checkbutton(exp_row, text="Rnd", variable=wi_data['post_msg_random']).pack(side=tk.LEFT, padx=(5, 0))
    
    def set_coordinate_for_window(self, window):
        self.log_message(f"Setting coords for: {window.title}")
        self.log_message("Move mouse to chat box in 3 seconds...")
        
        try:
            self.win32gui.ShowWindow(window._hWnd, self.win32con.SW_RESTORE)
            self.win32gui.SetForegroundWindow(window._hWnd)
            time.sleep(1)
        except:
            self.log_message("Could not activate window")
            return
        
        time.sleep(3)
        x, y = pyautogui.position()
        
        window_key = window.title
        self.window_coords[window_key] = {'x': x, 'y': y}
        self.save_config()
        
        self.log_message(f"Coords saved: X={x}, Y={y}")
        self.scan_habbo_windows()
    
    def set_coordinates_for_selected(self):
        selected_indices = [i for i, var in enumerate(self.window_vars) if var.get()]
        
        if not selected_indices:
            messagebox.showwarning("No Selection", "No windows selected!")
            return
        
        self.log_message(f"Setting coords for {len(selected_indices)} windows...")
        
        for i, idx in enumerate(selected_indices):
            if idx < len(self.habbo_windows):
                window_info = self.habbo_windows[idx]
                messagebox.showinfo("Set Coordinates", 
                    f"Position mouse for: {window_info['title']}\n\nClick OK, then wait 3 seconds.")
                self.set_coordinate_for_window(window_info['window'])
    
    def select_all_windows(self):
        for var in self.window_vars:
            var.set(True)
        self.log_message("All windows selected")
    
    def deselect_all_windows(self):
        for var in self.window_vars:
            var.set(False)
        self.log_message("All windows deselected")
    
    def log_message(self, message):
        timestamp = datetime.now().strftime("%H:%M:%S")
        log_line = f"[{timestamp}] {message}"
        
        self.log_text.configure(state='normal')
        self.log_text.insert(tk.END, log_line + "\n")
        self.log_text.configure(state='disabled')
        self.log_text.see(tk.END)
        self.canvas.configure(scrollregion=self.canvas.bbox("all"))
        print(log_line)
    
    def get_mouse_position(self):
        self.log_message("Move mouse to chat box in 3 seconds...")
        time.sleep(3)
        x, y = pyautogui.position()
        self.x_var.set(x)
        self.y_var.set(y)
        self.log_message(f"Position saved: X={x}, Y={y}")
        self.save_config()
    
    def activate_window(self, window_info):
        try:
            self.win32gui.ShowWindow(window_info['handle'], self.win32con.SW_RESTORE)
            self.win32gui.SetForegroundWindow(window_info['handle'])
            time.sleep(0.3)
            return True
        except:
            return False

    def get_selected_windows(self):
        windows_to_use = []
        for window_info, var in zip(self.habbo_windows, self.window_vars):
            if self.mode_var.get() == "all" or var.get():
                windows_to_use.append(window_info)
        return windows_to_use

    def get_post_msg_delay(self, window_info):
        use_random = window_info.get('post_msg_random', tk.BooleanVar()).get() or self.post_msg_random.get()
        if use_random:
            min_val = window_info.get('post_msg_delay_min', tk.DoubleVar()).get()
            max_val = window_info.get('post_msg_delay_max', tk.DoubleVar()).get()
            if min_val == max_val:
                return min_val
            return random.uniform(min_val, max_val)
        return window_info.get('post_msg_delay_min', tk.DoubleVar()).get()

    def get_message_for_window(self, window_info):
        if window_info.get('use_custom', tk.BooleanVar()).get():
            custom_msg = window_info.get('custom_message', tk.StringVar()).get().strip()
            if custom_msg:
                return custom_msg
            dropdown_msg = window_info.get('msg_dropdown_var', tk.StringVar()).get().strip()
            if dropdown_msg:
                return dropdown_msg
        if self.random_var.get():
            messages = self.get_message_list()
            if messages:
                return random.choice(messages)
        return self.message_var.get()
    
    def get_coordinates_for_window(self, window_info):
        window_key = window_info['title']
        if window_key in self.window_coords:
            coords = self.window_coords[window_key]
            if 'x' in coords and 'y' in coords:
                return coords['x'], coords['y']
        return self.x_var.get(), self.y_var.get()
    
    def bot_worker(self):
        cycle_count = 0
        
        while self.is_running:
            try:
                cycle_count += 1
                windows_to_use = self.get_selected_windows()
                
                if not windows_to_use:
                    self.log_message("No windows selected")
                    time.sleep(5)
                    continue
                
                self.log_message(f"Cycle #{cycle_count} - {len(windows_to_use)} window(s)")
                
                for i, window_info in enumerate(windows_to_use):
                    if not self.is_running:
                        break
                    
                    if i > 0:
                        offset = window_info.get('delay_after_prev', tk.DoubleVar()).get()
                        if offset > 0:
                            self.log_message(f"  Window offset {offset}s before {window_info['title']}")
                            time.sleep(offset)
                    
                    try:
                        self.log_message(f"  {window_info['title']}")
                        
                        if not self.activate_window(window_info):
                            self.log_message(f"    Failed to activate")
                            continue
                        
                        x, y = self.get_coordinates_for_window(window_info)
                        
                        time.sleep(random.uniform(0.2, 0.5))
                        pyautogui.click(x, y)
                        time.sleep(random.uniform(0.1, 0.3))
                        
                        message = self.get_message_for_window(window_info)
                        self.log_message(f"    '{message}'")
                        
                        pyautogui.write(message)
                        time.sleep(random.uniform(0.2, 0.4))
                        pyautogui.press('enter')
                        
                        post_delay = self.get_post_msg_delay(window_info)
                        if post_delay > 0:
                            time.sleep(post_delay)
                        
                    except Exception as e:
                        self.log_message(f"    Error: {str(e)}")
                
                if not self.is_running:
                    break
                    
                delay_minutes = self.delay_var.get()
                delay_seconds = delay_minutes * 60

                self.log_message(f"Cycle #{cycle_count} done. Next in {delay_minutes} min...")
                
                remaining = delay_seconds
                while remaining > 0 and self.is_running:
                    time.sleep(1)
                    remaining -= 1

                    if remaining % 30 == 0 and remaining > 0:
                        self.log_message(f"  {remaining // 60}:{remaining % 60:02d} remaining")
                
            except Exception as e:
                self.log_message(f"Bot error: {str(e)}")
                time.sleep(5)
        
        self.log_message("Bot stopped")
    
    def start_bot(self):
        if not self.habbo_windows:
            messagebox.showwarning("No Windows", "No Habbo windows found. Please scan first!")
            return
        
        windows_to_use = self.get_selected_windows()
        if not windows_to_use:
            messagebox.showwarning("No Selection", "No windows selected!")
            return
        
        self.save_config()
        
        self.is_running = True
        self.status_label.config(text="Status: RUNNING", foreground='green')
        self.start_button.config(state='disabled')
        self.stop_button.config(state='normal')
        
        self.log_message("=" * 40)
        self.log_message("BOT STARTED")
        self.log_message(f"Mode: {self.mode_var.get().upper()}")
        self.log_message(f"Windows: {len(windows_to_use)}")
        self.log_message(f"Cycle delay: {self.delay_var.get()} min")
        self.log_message(f"Random: {'ON' if self.random_var.get() else 'OFF'}")
        self.log_message("=" * 40)
        
        self.bot_thread = threading.Thread(target=self.bot_worker, daemon=True)
        self.bot_thread.start()
    
    def stop_bot(self):
        self.is_running = False
        self.status_label.config(text="Status: STOPPED", foreground='red')
        self.start_button.config(state='normal')
        self.stop_button.config(state='disabled')
        
        self.log_message("Bot stopping...")
        
        if self.bot_thread and self.bot_thread.is_alive():
            self.bot_thread.join(timeout=2)

def main():
    root = tk.Tk()
    
    try:
        root.iconbitmap('icon.ico')
    except:
        pass
    
    app = HabboMultiboxBotGUI(root)
    root.mainloop()

if __name__ == "__main__":
    main()
